# ===== API Keys =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TAVILY_API_KEY=your_tavily_api_key_here

# ===== Aliyun OSS =====
OSS_ACCESS_KEY_ID=your_oss_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret_here
OSS_BUCKET=your_oss_bucket_name_here
OSS_REGION=cn-shanghai
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_UPLOAD_DIR=uploads
OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-shanghai.aliyuncs.com

# ===== MySQL 数据库配置 =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=db_enterprise_ga

# ===== JWT 鉴权配置 =====
JWT_SECRET_KEY=change_me_to_a_strong_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== 大模型与嵌入模型配置（DashScope OpenAI 兼容端点）=====
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4

# ===== MinerU =====
MINERU_TOKEN=your_mineru_token_here
